# Ollama Cloud (OpenAI-compatible endpoint)
OLLAMA_API_KEY=
OLLAMA_URL=https://ollama.com/v1

# Reasoning and embedding models (runtime config — no hardcoded production names required)
NEMESIS_REASONING_MODEL=llama3:70b
NEMESIS_EMBED_MODEL=nomic-embed-text

# Binance Futures — use testnet first
BINANCE_KEY=
BINANCE_SECRET=
BINANCE_REST=https://testnet.binancefuture.com
BINANCE_WS=wss://stream.binancefuture.com

# Episodic memory (optional — in-memory fallback when unset)
QDRANT_URL=
QDRANT_API_KEY=

# Redis working memory (optional)
REDIS_URL=redis://localhost:6379/0

# Trading desk
NEMESIS_EQUITY=10000
NEMESIS_SYMBOL=btcusdt
NEMESIS_PAPER_MODE=true
